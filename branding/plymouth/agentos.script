# AgentOS Plymouth Boot Script
# Displays logo with animated spinner on a dark gradient background

# ── Background ────────────────────────────────────────────────────
Window.SetBackgroundTopColor(0.06, 0.05, 0.16);    # #0f0c29
Window.SetBackgroundBottomColor(0.14, 0.14, 0.24);  # #24243e

# ── Logo ──────────────────────────────────────────────────────────
logo.image = Image("logo.png");
logo.sprite = Sprite(logo.image);
logo.sprite.SetX(Window.GetWidth() / 2 - logo.image.GetWidth() / 2);
logo.sprite.SetY(Window.GetHeight() / 2 - logo.image.GetHeight() / 2 - 40);
logo.sprite.SetOpacity(1);

# ── Tagline ───────────────────────────────────────────────────────
tagline.image = Image("tagline.png");
tagline.sprite = Sprite(tagline.image);
tagline.sprite.SetX(Window.GetWidth() / 2 - tagline.image.GetWidth() / 2);
tagline.sprite.SetY(Window.GetHeight() / 2 + logo.image.GetHeight() / 2 - 10);
tagline.sprite.SetOpacity(0.5);

# ── Spinner ───────────────────────────────────────────────────────
spinner_frames = 36;
for (i = 0; i < spinner_frames; i++) {
    spinner[i] = Image("spinner-" + i + ".png");
}

spinner.sprite = Sprite();
spinner.sprite.SetX(Window.GetWidth() / 2 - spinner[0].GetWidth() / 2);
spinner.sprite.SetY(Window.GetHeight() / 2 + logo.image.GetHeight() / 2 + 40);

frame = 0;

fun refresh_callback() {
    spinner.sprite.SetImage(spinner[Math.Int(frame)]);
    frame = (frame + 0.3) % spinner_frames;
}
Plymouth.SetRefreshFunction(refresh_callback);

# ── Progress bar ──────────────────────────────────────────────────
progress_box.image = Image("progress-bg.png");
progress_box.sprite = Sprite(progress_box.image);
progress_box.sprite.SetX(Window.GetWidth() / 2 - progress_box.image.GetWidth() / 2);
progress_box.sprite.SetY(Window.GetHeight() - 80);

progress_bar.original_image = Image("progress-bar.png");
progress_bar.sprite = Sprite();
progress_bar.sprite.SetX(Window.GetWidth() / 2 - progress_box.image.GetWidth() / 2 + 2);
progress_bar.sprite.SetY(Window.GetHeight() - 78);

fun progress_callback(duration, progress) {
    if (progress_bar.original_image.GetWidth() > 0) {
        new_width = Math.Int(progress_bar.original_image.GetWidth() * progress);
        if (new_width > 0) {
            progress_bar.image = progress_bar.original_image.Scale(new_width, progress_bar.original_image.GetHeight());
            progress_bar.sprite.SetImage(progress_bar.image);
        }
    }
}
Plymouth.SetBootProgressFunction(progress_callback);

# ── Password prompt (for encrypted disks) ────────────────────────
fun display_password_callback(prompt, bullets) {
    bullet_image = Image("bullet.png");
    total_width = bullets * (bullet_image.GetWidth() + 4);
    start_x = Window.GetWidth() / 2 - total_width / 2;

    for (i = 0; i < bullets; i++) {
        bullet[i].sprite = Sprite(bullet_image);
        bullet[i].sprite.SetX(start_x + i * (bullet_image.GetWidth() + 4));
        bullet[i].sprite.SetY(Window.GetHeight() / 2 + 120);
    }
}
Plymouth.SetDisplayPasswordFunction(display_password_callback);

# ── Message display ───────────────────────────────────────────────
message.sprite = Sprite();
fun message_callback(text) {
    message.image = Image.Text(text, 0.7, 0.7, 0.7, "Sans 11");
    message.sprite.SetImage(message.image);
    message.sprite.SetX(Window.GetWidth() / 2 - message.image.GetWidth() / 2);
    message.sprite.SetY(Window.GetHeight() - 40);
}
Plymouth.SetMessageFunction(message_callback);
